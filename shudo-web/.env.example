# Public browser configuration. These values identify the Supabase project;
# they are not service-role secrets.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Generate at least 32 random characters and configure this same
# value as SHUDO_CLEANUP_SECRET in Supabase. Vercel sends it only to the daily
# keepalive route, which relays an idempotent cleanup drain to Supabase.
CRON_SECRET=
