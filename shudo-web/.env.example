# Public browser configuration. These values identify the Supabase project;
# they are not service-role secrets.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only bearer credential that Vercel uses to protect the scheduled route.
CRON_SECRET=

# Server-only, distinct credentials relayed to their matching Supabase Edge
# Functions. Generate at least 32 random characters for each; configure the
# same values as Supabase Edge Function secrets, and never expose them as
# NEXT_PUBLIC variables.
SHUDO_CLEANUP_SECRET=
SHUDO_WEEKLY_SECRET=
