# Supabase injects SUPABASE_URL, SUPABASE_ANON_KEY, and
# SUPABASE_SERVICE_ROLE_KEY into hosted Edge Functions automatically.
OPENAI_API_KEY=

# Dedicated high-entropy secret (at least 32 characters) for the scheduled
# Storage cleanup endpoint.
# Generate it outside the repository and store the hosted value in Supabase
# Edge Function secrets and the Cron request header.
SHUDO_CLEANUP_SECRET=

# Required: set at least one owner guard. Functions fail closed without it.
# Both may be set; when both are present, both must match the signed-in user.
SHUDO_OWNER_USER_ID=
SHUDO_OWNER_EMAIL=
